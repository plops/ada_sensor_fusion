project Kalman_Fusion_Stream is

   for Source_Dirs use ("src");
   for Main use ("kalman_fusion_stream.adb");
   for Exec_Dir use "bin";
   for Object_Dir use "obj";

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-Wall", "-O2");
   end Compiler;

   package Binder is
      for Default_Switches ("Ada") use ("-Es");
   end Binder;

end Kalman_Fusion_Stream;
