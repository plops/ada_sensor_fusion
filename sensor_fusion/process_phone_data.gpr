-- Project for processing phone data CSV files

project Process_Phone_Data is

   for Source_Dirs use ("src/");
   for Object_Dir use "obj/process";
   for Exec_Dir use "bin";
   for Main use ("process_phone_data.adb");

   package Compiler is
      for Default_Switches ("Ada") use 
        ("-gnat2020", "-Wall", "-g");
   end Compiler;

   package Builder is
      for Switches ("Ada") use ("-j0");
   end Builder;

end Process_Phone_Data;
