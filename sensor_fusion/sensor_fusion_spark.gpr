project Sensor_Fusion_SPARK is

   for Source_Dirs use ("src");
   for Main use ("sensor_fusion_main.adb");
   for Exec_Dir use "bin";
   for Object_Dir use "obj";

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-Wall", "-O2");
   end Compiler;

   package Binder is
      for Default_Switches ("Ada") use ("-Es");
   end Binder;

   package Prove is
      for Prove_Switches ("Ada") use ("-steps=0", "-timeout=120");
   end Prove;

end Sensor_Fusion_SPARK;
