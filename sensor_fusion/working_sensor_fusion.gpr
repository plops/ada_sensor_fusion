-- Working Ada Sensor Fusion Server Project
-- Uses GNAT.Sockets instead of AWS dependencies

project Working_Sensor_Fusion is

   for Source_Dirs use ("src/");
   for Object_Dir use "obj/working";
   for Exec_Dir use "bin";
   for Main use ("working_sensor_fusion.adb");

   package Compiler is
      for Default_Switches ("Ada") use 
        ("-gnat2020", "-Wall", "-g");
   end Compiler;

   package Builder is
      for Switches ("Ada") use ("-j0");
   end Builder;

end Working_Sensor_Fusion;
