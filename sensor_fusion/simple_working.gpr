project Simple_Working is

   for Source_Dirs use ("src");
   for Main use ("simple_http_server_working.adb");
   for Exec_Dir use "bin";
   for Object_Dir use "obj";

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-Wall", "-O2");
   end Compiler;

   package Binder is
      for Default_Switches ("Ada") use ("-Es");
   end Binder;

end Simple_Working;
